# ============================================================================
#  👉 PASTE YOUR KEYS HERE  (project-root .env — read by docker compose)
#  ----------------------------------------------------------------------------
#  Everything that does NOT need one of your private accounts is already set.
#  Fill the 3 REQUIRED items marked  >>> PASTE ... <<<  (WhatsApp is optional),
#  then run:   docker compose up -d --force-recreate backend
# ============================================================================

# ---- App (pre-configured, no action needed for local dev) ----
PUBLIC_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Groq — vision extraction + agent (REQUIRED) ----
# Get a key at https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# ---- MongoDB (pre-configured for docker-compose, no action needed) ----
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=visiting_cards

# ---- Google Sheets (REQUIRED) ----
# 1) GCP project → enable "Google Sheets API"
# 2) create a Service Account → download its JSON key
# 3) paste the ENTIRE json on ONE line below (replace newlines), e.g.
#    GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# 4) create a Sheet, share it (Editor) with the service-account email
#    (the "client_email" inside the JSON), and put the Sheet ID below.
GOOGLE_SERVICE_ACCOUNT_JSON=>>> PASTE YOUR SERVICE-ACCOUNT JSON (one line) HERE <<<
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEET_ID=>>> PASTE YOUR GOOGLE SHEET ID HERE <<<
GOOGLE_WORKSHEET_NAME=Contacts

# ---- WhatsApp Business / Meta Cloud API (OPTIONAL — leave blank to skip alerts) ----
# https://developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Manager number in E.164 without '+', e.g. 919876543210
WHATSAPP_MANAGER_NUMBER=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en_US

# ---- Audio transcription (OPTIONAL) ----
# none = store audio + URL only (meets the requirement).
# openai = also transcribe with Whisper (needs OPENAI_API_KEY below).
TRANSCRIPTION_PROVIDER=none
OPENAI_API_KEY=

# ---- Bonus features ----
# true = agent pauses for your confirmation before writing to Sheets / WhatsApp.
HUMAN_IN_THE_LOOP=false
# true = agent guesses company website / LinkedIn from the company name.
ENABLE_ENRICHMENT=true
